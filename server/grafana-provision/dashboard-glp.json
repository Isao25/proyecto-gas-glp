{
  "dashboard": {
    "uid": "glp-dash",
    "title": "Detector de Fuga de GLP",
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 0,
    "refresh": "5s",
    "time": { "from": "now-15m", "to": "now" },
    "panels": [
      {
        "id": 1,
        "type": "timeseries",
        "title": "Concentracion de GLP (ppm)",
        "gridPos": { "h": 10, "w": 18, "x": 0, "y": 0 },
        "datasource": { "type": "influxdb", "uid": "influxdb-glp" },
        "fieldConfig": {
          "defaults": {
            "unit": "ppm",
            "min": 0,
            "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "lineWidth": 2, "gradientMode": "scheme", "showPoints": "never" },
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ] },
            "color": { "mode": "thresholds" }
          }
        },
        "options": { "tooltip": { "mode": "single" }, "legend": { "displayMode": "hidden" } },
        "targets": [ {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-glp" },
          "query": "from(bucket: \"gas\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetria\" and r._field == \"ppm\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)"
        } ]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Ultimo valor",
        "gridPos": { "h": 10, "w": 6, "x": 18, "y": 0 },
        "datasource": { "type": "influxdb", "uid": "influxdb-glp" },
        "fieldConfig": {
          "defaults": {
            "unit": "ppm",
            "thresholds": { "mode": "absolute", "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1000 },
              { "color": "red", "value": 2000 }
            ] },
            "color": { "mode": "thresholds" }
          }
        },
        "options": { "graphMode": "area", "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
        "targets": [ {
          "refId": "A",
          "datasource": { "type": "influxdb", "uid": "influxdb-glp" },
          "query": "from(bucket: \"gas\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"telemetria\" and r._field == \"ppm\")\n  |> last()"
        } ]
      }
    ]
  },
  "overwrite": true
}
